  "dependencies": {
    "@google/genai": "^1.13.0",
    "@mistralai/mistralai": "^1.7.5",
    "axios": "^1.11.0",
    "express": "^5.1.0",
    "form-data": "^4.0.4",
    "openai": "^5.12.2",
    "wav": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@tsconfig/node22": "^22.0.2",
